{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "packages/typescript-config/*.json",
    "packages/eslint-config/*.js",
    "packages/prettier-config/*.json",
    ".prettierignore"
  ],
  "tasks": {
    "typecheck": {},
    "lint": {},
    "lint:fix": {},
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    }
  }
}
