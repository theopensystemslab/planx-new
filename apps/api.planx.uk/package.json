{
  "name": "api.planx.uk",
  "license": "MPL-2.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "type": "module",
  "exports": "./dist/index.js",
  "engines": {
    "node": ">=24.14"
  },
  "dependencies": {
    "@airbrake/node": "^2.1.9",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@opensystemslab/planx-core": "github:theopensystemslab/planx-core#272916e",
    "@types/isomorphic-fetch": "^0.0.36",
    "adm-zip": "^0.5.16",
    "ai": "^6.0.105",
    "axios": "^1.13.6",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.1",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.6",
    "csv-stringify": "^6.6.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-jwt": "^8.5.1",
    "express-rate-limit": "^8.2.1",
    "form-data": "^4.0.5",
    "graphql": "^16.13.0",
    "graphql-request": "^4.3.0",
    "he": "^1.2.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^2.0.9",
    "husky": "^8.0.3",
    "isomorphic-fetch": "^3.0.0",
    "jsdom": "^28.1.0",
    "jsondiffpatch": "^0.7.3",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "mime": "^4.1.0",
    "multer": "^2.1.0",
    "nanoid": "^5.1.6",
    "notifications-node-client": "^8.3.0",
    "openid-client": "^5.7.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino-http": "^11.0.0",
    "sanitize-filename": "^1.6.3",
    "slack-notify": "^2.0.7",
    "string-to-stream": "^3.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "type-fest": "^4.41.0",
    "zod": "^3.25.76"
  },
  "scripts": {
    "dev": "tsx watch index.ts",
    "start": "node ./dist/index.js",
    "lint": "eslint '**/*.{js,ts}' && prettier -c .",
    "lint:fix": "eslint --fix '**/*.{js,ts}' && prettier -w .",
    "check": "tsc --noEmit && pnpm lint",
    "test": "TZ=Europe/London vitest run",
    "test:coverage": "TZ=Europe/London vitest run --coverage && open coverage/lcov-report/index.html",
    "test:watch": "TZ=Europe/London vitest --ui --coverage",
    "build": "rimraf ./dist && npx tsc && pnpm copy-swagger-files && pnpm copy-prompt-files",
    "prepare": "cd ../.. && husky install apps/api.planx.uk/.husky",
    "copy-swagger-files": "copyfiles '**/docs.yaml' dist",
    "copy-prompt-files": "copyfiles 'modules/ai/**/*.md' dist"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "eslint --fix",
      "prettier -w"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@types/adm-zip": "^0.5.7",
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^4.17.25",
    "@types/express-pino-logger": "^4.0.6",
    "@types/he": "^1.2.3",
    "@types/jsdom": "^27.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^2.0.0",
    "@types/node": "~24.10.15",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "graphql-query-test-mock": "^0.12.1",
    "json-stringify-pretty-compact": "^3.0.0",
    "lint-staged": "^15.5.2",
    "nock": "^13.5.6",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "uuid": "^11.1.0",
    "vite": "^6.4.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "nock": "13"
      },
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    },
    "onlyBuiltDependencies": [
      "@opensystemslab/planx-core"
    ],
    "overrides": {
      "fast-xml-parser": "^5.4.1",
      "qs@<6.14.1": ">=6.14.1"
    }
  }
}
