{
  "extends": "@planx/typescript-config/node.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true,
    // ensure the code is ready for per-file transpilation by tsx (used in dev mode)
    "verbatimModuleSyntax": true,
    "types": ["vitest/globals"]
  },
  "exclude": ["node_modules", "dist"]
}
