{
  "$schema": "https://turborepo.com/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**", "!build/storybook/**"],
      "env": ["VITE_*"]
    },
    "build-storybook": {
      "dependsOn": ["build"],
      "outputs": ["build/storybook/**"],
      "env": ["VITE_*"]
    }
  }
}
