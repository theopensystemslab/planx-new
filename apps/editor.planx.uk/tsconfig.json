{
  "extends": "@planx/typescript-config/react.json",
  "compilerOptions": {
    "baseUrl": "src",
    "allowSyntheticDefaultImports": true,
    "typeRoots": [
      "./types",
      "./node_modules/@types",
      "./node_modules",
    ],
    "types": [
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom",
      "@types/jest-axe",
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
